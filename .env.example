# Public client config only — these are embedded in the browser bundle.
# NEVER put Gemini keys, service_role keys, or admin passwords in VITE_* vars.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Google Analytics 4 is configured in index.html + src/components/GoogleAnalytics.tsx
# Measurement ID: G-VJHYYKV4F7 (public client ID — not a secret)

# Optional (dev only). Prefer Admin → Intégrations + Edge Function in production.
# VITE_GEMINI_API_KEY=

# Optional third-party (prefer server-side proxy if the key is secret)
# VITE_API_NINJAS_KEY=

# --- Contact form (NOT Vercel / NOT VITE_*) ---
# Set these as Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets):
#   RESEND_API_KEY=re_xxxxxxxx
#   CONTACT_TO_EMAIL=contact@autodevisexpert.com
#   CONTACT_FROM_EMAIL=AutoDevis Expert <noreply@autodevisexpert.com>
# Verify the domain (or noreply@) in Resend before production e-mail delivery.
# The form still stores messages in `contact_messages` even if Resend is unset.
