# Public client config only — these are embedded in the browser bundle.
# NEVER put Gemini keys, service_role keys, or admin passwords in VITE_* vars.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Optional (dev only). Prefer Admin → Intégrations + Edge Function in production.
# VITE_GEMINI_API_KEY=

# Optional third-party (prefer server-side proxy if the key is secret)
# VITE_API_NINJAS_KEY=
